		{
			"functionName": "WriteCMDLineByLine",
			"functionDescription": "",
			"functionCategory": "",
			"functionReturnType": "none",
			"functionCopyPicked": false,
			"functionIsAsync": false,
			"functionParameters": [
				{
					"name": "CMDString",
					"type": "string",
					"initialValue": "",
					"comment": "",
					"sid": 442279885973608
				}
			],
			"eventType": "function-block",
			"conditions": [],
			"actions": [],
			"sid": 689540239993308,
			"children": [
				{
					"eventType": "block",
					"conditions": [],
					"actions": [
						{
							"type": "script",
							"language": "javascript",
							"script": [
								"const htmlString = localVars.CMDString;",
								"",
								"const winInst = runtime.objects.cmdEndOfShift.getFirstPickedInstance();",
								"",
								"if (winInst) {",
								"    const wrapper = winInst.getElement().querySelector('.cmd-body');",
								"    ",
								"    if (wrapper) {",
								"",
								"        const temp = document.createElement('div');",
								"        temp.innerHTML = htmlString;",
								"        ",
								"        // Extract all the top-level HTML tags",
								"        const lines = Array.from(temp.children);",
								"        let i = 0;",
								"",
								"        const printNextLine = () => {",
								"            if (i < lines.length) {",
								"                const currentLine = lines[i];",
								"                ",
								"                // Append and scroll to bottom",
								"                wrapper.appendChild(currentLine);",
								"                wrapper.scrollTop = wrapper.scrollHeight;",
								"                i++;",
								"                ",
								"                runtime.callFunction(\"PlaySound\", \"typewriter-key-1\");",
								"",
								"                let nextDelay = 100; ",
								"                ",
								"                if (i < lines.length) {",
								"                    const nextLine = lines[i];",
								"",
								"                    if (nextLine.querySelector('#eos-total')) {",
								"                        nextDelay = 300; ",
								"                    }",
								"",
								"                    else if (nextLine.querySelector('#eos-sleep')) {",
								"                        nextDelay = 200;",
								"                    }",
								"                }",
								"                ",
								"                setTimeout(printNextLine, nextDelay);",
								"            }",
								"        };",
								"        ",
								"        setTimeout(printNextLine, 500);",
								"    }",
								"}",
								""
							]
						}
					],
					"sid": 125722699947584
				}
			]
		},
