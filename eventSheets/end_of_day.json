									}
								},
								{
									"callFunction": "WriteCMDLineByLine",
									"sid": 528403081454451,
									"parameters": [
										"\"  <div style='font-weight: bold;'>SHIFT EARNINGS ACCOUNTING:</div>\n  <div>==========================</div>\n  \n  <div class='cmd-row' style='border-bottom: 1px dotted #005522;'>\n    <span>Base Salary For Processed Tickets:</span>\n    <span id='eos-salary'>$\" & ShiftSalary & \"</span>\n  </div>\n  <div class='cmd-row' style='border-bottom: 1px dotted #005522;'>\n    <span>Accuracy Deductions From Fines:</span>\n    <span id='eos-penalty' class='rate-negative'>-$\" & ShiftPenalty & \"</span>\n  </div>\n  \n  <div class='cmd-row' style='margin-top: 8px;'>\n    <span>= NET SALARY:</span>\n    <span id='eos-net' style='font-weight:bold;'>$\" & netSalary & \"</span>\n  </div>\n  \n  <br>\n  <div style='font-weight: bold;'>HOUSEHOLD EXPENSES:</div>\n  <div>===================</div>\n  <div class='cmd-row' style='border-bottom: 1px dotted #005522;'>\n    <span>Food Expenses:</span>\n    <span class='rate-negative'>-$\" & foodCost & \"</span>\n  </div>\n  <div class='cmd-row' style='border-bottom: 1px dotted #005522;'>\n    <span>Rent Utility:</span>\n    <span class='rate-negative'>-\" & rentCost & \"</span>\n  </div>\n\n  <br>\n  <div style='font-weight: bold;'>OPTIONAL WORKSTATION UPGRADES:</div>\n  <div>==============================</div>\n  <div class='cmd-row' style='border-bottom: 1px dotted #005522; padding-bottom: 4px;'>\n    <span>Upgrade Internet Plan:</span>\n<div>\n      <span class='rate-negative' style='margin-right: 12px;'>-$30.00</span>\n      \" & btnNet & \"\n    </div>\n  </div>\n  <div class='cmd-row' style='border-bottom: 1px dotted #005522; padding-top: 4px; padding-bottom: 4px;'>\n    <span>Upgrade CPU Speed:</span>\n<div>\n      <span class='rate-negative' style='margin-right: 12px;'>-$20.00</span>\n      \" & btnCpu & \"\n    </div>\n  </div>\n  <div class='cmd-row' style='border-bottom: 1px dotted #005522; padding-top: 4px; padding-bottom: 4px;'>\n    <span>Reduce Credibility Rate Drain:</span>\n<div>\n      <span class='rate-negative' style='margin-right: 12px;'>-$40.00</span>\n      \" & btnDrain & \"\n    </div>\n  </div>\n\n  <br>\n  <div class='cmd-row' style='margin-top: 8px;'>\n    <span>= REMAINING SAVINGS:</span>\n    <span id='eos-total' style='color: #00ff66; font-weight: bold; font-size: 18px;'>$\" & TotalSavings & \"</span>\n  </div>\n\n  <div style='text-align: center; margin-top: 24px;'>\n    <button id='eos-proceed' class='cmd-btn'>[ PROCEED ]</button>\n  </div>\""
									]
								}
